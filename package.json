{
  "name": "blockchain-dapp",
  "version": "1.0.0",
  "description": "This project demonstrates a basic Hardhat use case. It comes with a sample contract, a test for that contract, and a Hardhat Ignition module that deploys that contract.",
  "main": "hardhat.config.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:yoda:local": "hardhat run scripts/deployYoda.js --network localhost",
    "deploy:yoda:sepolia": "hardhat run scripts/deployYoda.js --network sepolia",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "scenario:purchase": "hardhat run scripts/test_purchase.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sadiqram/Blockchain-DApp.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sadiqram/Blockchain-DApp/issues"
  },
  "homepage": "https://github.com/sadiqram/Blockchain-DApp#readme",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
